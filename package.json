{
  "name": "todo-api",
  "version": "1.0.0",
  "description": "Small API for task management",
  "main": "start.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --clear --watch --debug --respawn --transpile-only ./start.ts",
    "test": "mocha --timeout 60000 -r ts-node/register 'tests/**/*.ts'",
    "lint-fix": "eslint '**/**/*.{ts,tsx}' --quiet --fix",
    "start": "node ./dist/start.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergio17791/todo-api.git"
  },
  "keywords": [
    "todo"
  ],
  "author": "Sergio Muñoz Buitrón",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sergio17791/todo-api/issues"
  },
  "homepage": "https://github.com/sergio17791/todo-api#readme",
  "dependencies": {
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "express-validator": "^6.14.1",
    "http-status-codes": "^2.2.0",
    "mongoose": "^6.3.8"
  },
  "devDependencies": {
    "@types/chai-as-promised": "^7.1.5",
    "@types/express": "^4.17.13",
    "@types/mocha": "^9.1.1",
    "@types/node": "^17.0.42",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.28.0",
    "chai": "^4.3.6",
    "chai-as-promised": "^7.1.1",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "mocha": "^10.0.0",
    "mongodb-memory-server": "^8.6.0",
    "prettier": "^2.7.0",
    "supertest": "^6.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.7.3"
  }
}
